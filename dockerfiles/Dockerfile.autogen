FROM python:3.12-slim
WORKDIR /app
RUN pip install --no-cache-dir pyautogen fastapi uvicorn anthropic openai httpx
COPY packages/agents/agent_http_wrapper.py .
COPY packages/agents/autogen_agent.py .
COPY packages/core/ ./core/
ENV AGENT_CLASS=AutoGenAgent
ENV AGENT_MODULE=autogen_agent
CMD ["uvicorn", "agent_http_wrapper:app", "--host", "0.0.0.0", "--port", "8000"]
