FROM python:3.12-slim
WORKDIR /app
RUN pip install --no-cache-dir llama-index fastapi uvicorn anthropic openai httpx
COPY packages/agents/agent_http_wrapper.py .
COPY packages/agents/llamaindex_agent.py .
COPY packages/core/ ./core/
ENV AGENT_CLASS=LlamaIndexAgent
ENV AGENT_MODULE=llamaindex_agent
CMD ["uvicorn", "agent_http_wrapper:app", "--host", "0.0.0.0", "--port", "8000"]
