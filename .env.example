# ═══════════════════════════════════════════════════════════════════
# OneAgent OS — Environment Variables
# ═══════════════════════════════════════════════════════════════════

# ══════════════════════════════════════════════════════════════
# WindsurfAPI — Free LLM Gateway (Tier 2 in HybridLLMRouter)
# ══════════════════════════════════════════════════════════════

# ⬇ الأهم — بدونه WindsurfAPI مش هيشتغل خالص
CODEIUM_AUTH_TOKEN=          # من: windsurf.com/show-auth-token (مجاني)

WINDSURF_API_URL=http://windsurf-api:3003
WINDSURF_API_KEY=            # مفتاح داخلي اختاريه انتِ — أي string قوي
WINDSURF_DASHBOARD_PASSWORD= # password لـ http://localhost:3003/dashboard

# الـ SDKs بتشاور هنا أوتوماتيك → WindsurfAPI
OPENAI_BASE_URL=http://windsurf-api:3003/v1
OPENAI_API_KEY=${WINDSURF_API_KEY}
ANTHROPIC_BASE_URL=http://windsurf-api:3003
ANTHROPIC_API_KEY=${WINDSURF_API_KEY}

# الـ model الافتراضي عبر WindsurfAPI
DEFAULT_MODEL=claude-sonnet-4-6

# ── LLM APIs ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=

# ── Infrastructure ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
POSTGRES_URL=postgresql://oneagent:oneagent_pass@localhost:5432/oneagent
QDRANT_URL=http://localhost:6333
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── Search Tools ──────────────────────────────────────────────────
SERPER_API_KEY=
TAVILY_API_KEY=

# ── Monitoring ────────────────────────────────────────────────────
SENTRY_DSN=
OPENTELEMETRY_ENDPOINT=

# ── App ───────────────────────────────────────────────────────────
SECRET_KEY=dev-secret-key-change-in-production
ENVIRONMENT=development
MAX_TOKENS_PER_REQUEST=4096
TOKEN_BUDGET_USD=0.01
API_PORT=8000
API_HOST=0.0.0.0
