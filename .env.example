# ═══════════════════════════════════════════════════════════════════
# OneAgent OS — Environment Variables
# ═══════════════════════════════════════════════════════════════════

# ── LLM APIs ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=

# ── Infrastructure ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
POSTGRES_URL=postgresql://oneagent:oneagent_pass@localhost:5432/oneagent
QDRANT_URL=http://localhost:6333
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── Search Tools ──────────────────────────────────────────────────
SERPER_API_KEY=
TAVILY_API_KEY=

# ── Monitoring ────────────────────────────────────────────────────
SENTRY_DSN=
OPENTELEMETRY_ENDPOINT=

# ── Cloudflare ───────────────────────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=37f918bd5741e78da7136f45f4f3b6fb
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_API_TOKEN_DEPLOY=
CLOUDFLARE_API_TOKEN_DEPLOY2=
API_HOST=0.0.0.0

# ── Auth ─────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production
ALLOWED_ORIGINS=http://localhost:3000,https://jnus.pages.dev,https://oneagent-os.pages.dev
